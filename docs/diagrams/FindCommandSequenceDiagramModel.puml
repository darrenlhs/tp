@startuml
!include style.puml
skinparam ArrowFontStyle plain

title Find Command Part 2 -- Model

box Logic LOGIC_COLOR_T1
participant ":Logic" as Logic LOGIC_COLOR

end box

box Model MODEL_COLOR_T1
participant ":PersonMatchesKeywordPredicate" as Pmkp MODEL_COLOR
participant "model:ModelManager" as Model MODEL_COLOR
participant ":FilteredList<Person>" as FilteredPersons MODEL_COLOR
end box

[-> Logic : execute("find john")
activate Logic

create Pmkp
Logic -> Pmkp : New PersonMatchesKeywordPredicate(<Keywords>)
activate Pmkp
Pmkp --> Logic : Predicate
deactivate Pmkp

Logic -> Model : updateFilteredPersonListStacked(Predicate)
activate Model

Model -> FilteredPersons : setPredicate(Predicate)
activate FilteredPersons
deactivate FilteredPersons

deactivate Model
@enduml
